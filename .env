# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- App ---------------------------------------------------------------
APP_NAME="APNA AI - Shopping Assistant"
APP_ENV=production
DEBUG=false
PORT=8000

# --- Database (same Railway PostgreSQL as your Node.js backend) --------
DATABASE_URL=mysql://root:ZcnePvCtUcgRcKPJgtisIwYQPJvueGKg@zephyr.proxy.rlwy.net:42866/railway
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# --- Auth ----------------------------------------------------------------
# MUST be the exact same secret your Node.js backend uses to sign JWTs.
JWT_SECRET=mysecret9525
JWT_ALGORITHM=HS256
# The claim name in your JWT payload that holds the user's id.
JWT_USER_ID_CLAIM=id

# --- LLM provider --------------------------------------------------------
LLM_PROVIDER=gemini
OPENAI_API_KEY=
GEMINI_API_KEY=AQ.Ab8RN6KHs-ANJpR-Q2rNdEUvwSjOfbyk32t_fKHiA6EzGAe3mg
MODEL_NAME=gemini-2.5-flash
LLM_REQUEST_TIMEOUT=30
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.4

# --- Conversation memory ---------------------------------------------
MAX_MEMORY_MESSAGES=20
MEMORY_BACKEND=in_memory

# --- CORS (comma-separated list of allowed origins) --------------------
CORS_ORIGINS=https://assignment-74-1.netlify.app

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
